# EnrollSalud — environment variables (names only; never commit real values).

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Email (Resend)
RESEND_API_KEY=

# Cron jobs — shared secret sent by Vercel Cron as `Authorization: Bearer <CRON_SECRET>`.
# Required by /api/cron/renewals and /api/cron/lead-reminders. Routes fail closed if unset.
CRON_SECRET=
